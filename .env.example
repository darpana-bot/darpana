# ============================================================
# DARPANA — Environment Variables Example
# ============================================================
# Salin file ini menjadi `.env` dan isi nilai sebenarnya.
# JANGAN commit file `.env` yang berisi API key asli ke GitHub!
# ============================================================

# --- WAJIB: Groq API Key untuk fitur Sumur Akasa (AI chat) ---
# Dapatkan gratis di: https://console.groq.com/keys
# Login pakai Google atau GitHub, klik "Create API Key"
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- OPSIONAL: Pilih model Groq ---
# Default: llama-3.3-70b-versatile (paling cerdas, agak lambat)
# Alternatif cepat: llama-3.1-8b-instant
GROQ_MODEL=llama-3.3-70b-versatile

# --- OPSIONAL: Port server ---
# Default: 8787. Production platform biasanya set PORT otomatis.
PORT=8787

# --- OPSIONAL: Port Vite dev server (hanya untuk dev lokal) ---
VITE_PORT=5173
